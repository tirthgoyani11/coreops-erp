# Backend Environment Variables Template
# Copy this file to .env and configure appropriately

PORT=5000
NODE_ENV=development

# Database
# IMPORTANT: Use a secure MongoDB connection string in production
MONGO_URI=mongodb://localhost:27017/coreops

# JWT Configuration
# IMPORTANT: Generate a secure secret for production (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_USE_64_PLUS_CHARS
JWT_EXPIRES_IN=7d

# CORS - Comma-separated list of allowed origins
# IMPORTANT: Set actual frontend domains in production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
# Levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Seed Admin Credentials (for initial setup only)
# IMPORTANT: Set these before running seed, then remove or disable
# SEED_ADMIN_EMAIL=admin@yourcompany.com
# SEED_ADMIN_PASSWORD=YourSecurePassword123!
# SEED_ADMIN_NAME=Super Admin

# Production-only settings
# Set ALLOW_SEED=true only when needed, then disable immediately
# ALLOW_SEED=false

# Custom logs directory (defaults to ./logs)
# LOGS_DIR=/var/log/coreops
